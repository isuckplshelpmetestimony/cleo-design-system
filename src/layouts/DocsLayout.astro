---
import { ClientRouter } from 'astro:transitions';
import Sidebar from '../components/docs/Sidebar.astro';
import '../styles/global.css';
import '../styles/components.css';
import '../components/cleo/cleo.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Cleo Design System — Quiet Authority' } = Astro.props;
const currentPath = Astro.url.pathname;
const pageTitle = title === 'Cleo' ? 'Cleo Design System' : `${title} · Cleo Design System`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500&family=Lora:ital,wght@0,400&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <ClientRouter />
  </head>
  <body>
    <div class="docs-shell">
      <Sidebar currentPath={currentPath} />
      <main class="docs-main">
        <article class="docs-content" transition:name="docs-content" transition:animate="fade">
          <slot />
        </article>
      </main>
    </div>
  </body>
</html>

<style>
  .docs-shell {
    display: flex;
    min-height: 100vh;
  }

  .docs-main {
    flex: 1;
    margin-left: var(--sidebar-width);
    min-width: 0;
  }

  .docs-content {
    padding: var(--content-padding-y) var(--content-padding-x);
    padding-left: max(var(--content-padding-x), 4rem);
    max-width: calc(var(--content-max) + var(--content-padding-x) * 2 + 120px);
  }

  .docs-content :global(.wide-band) {
    margin-left: calc(-1 * var(--content-padding-x));
    margin-right: calc(-1 * min(var(--content-padding-x), 2rem));
    padding-left: var(--content-padding-x);
    padding-right: var(--content-padding-x);
    max-width: 1100px;
  }

  @media (max-width: 900px) {
    .docs-main {
      margin-left: 0;
    }

    .docs-shell {
      flex-direction: column;
    }
  }
</style>

<style is:global>
  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  ::view-transition-old(docs-content),
  ::view-transition-new(docs-content) {
    animation-duration: var(--duration-base, 300ms);
    animation-timing-function: var(--ease-out, cubic-bezier(0, 0, 0.2, 1));
  }

  ::view-transition-new(docs-content) {
    animation-name: fade-in;
  }
</style>

<script>
  document.addEventListener('astro:after-swap', () => {
    window.scrollTo(0, 0);
  });
</script>
