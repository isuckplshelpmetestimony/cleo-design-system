---
/** Note cards — combined: left accent, metadata, status + icon */
---

<div class="card-showcase">
  <article class="card-showcase__item">
    <div class="cleo-note-card cleo-note-card--draft">
      <h4 class="cleo-note-card__name">Maria Chen</h4>
      <p class="cleo-note-card__type">Initial evaluation</p>
      <p class="cleo-note-card__meta">Last edited · 10:42 PM</p>
      <div class="cleo-note-card__footer">
        <span class="cleo-status cleo-status--draft">
          <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden>
            <circle cx="7" cy="7" r="5.5" fill="none" stroke="currentColor" stroke-width="1.25"></circle>
          </svg>
          Draft
        </span>
      </div>
    </div>
    <span class="card-showcase__caption">Draft</span>
  </article>

  <article class="card-showcase__item">
    <div class="cleo-note-card cleo-note-card--progress">
      <h4 class="cleo-note-card__name">James Okonkwo</h4>
      <p class="cleo-note-card__type">Progress note</p>
      <p class="cleo-note-card__meta">Transcribing your visit…</p>
      <div class="cleo-note-card__footer">
        <span class="cleo-status cleo-status--progress">
          <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden>
            <circle cx="3" cy="7" r="1" fill="currentColor"></circle>
            <circle cx="7" cy="7" r="1" fill="currentColor"></circle>
            <circle cx="11" cy="7" r="1" fill="currentColor"></circle>
          </svg>
          In progress
        </span>
      </div>
    </div>
    <span class="card-showcase__caption">In progress</span>
  </article>

  <article class="card-showcase__item">
    <div class="cleo-note-card cleo-note-card--complete">
      <h4 class="cleo-note-card__name">Patricia Wells</h4>
      <p class="cleo-note-card__type">Discharge summary</p>
      <p class="cleo-note-card__meta">Signed · May 16, 2026 at 4:47 PM</p>
      <div class="cleo-note-card__footer">
        <span class="cleo-status cleo-status--complete">
          <svg width="14" height="14" viewBox="0 0 24 24" aria-hidden class="cleo-status__check">
            <path d="M7 12l3 3 7-7" fill="none" stroke="#D4841A" stroke-width="2"></path>
          </svg>
          Complete
        </span>
      </div>
    </div>
    <span class="card-showcase__caption">Complete</span>
  </article>
</div>
