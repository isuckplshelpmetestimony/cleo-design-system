---
interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<div class="showcase wide-band">
  {title && <h3>{title}</h3>}
  <div class="showcase-demo">
    <slot name="demo" />
  </div>
  {Astro.slots.has('annotations') && (
    <div class="showcase-annotations">
      <slot name="annotations" />
    </div>
  )}
</div>

<style>
  .showcase {
    background: var(--color-fog);
    border-radius: var(--radius-md);
    padding: var(--space-10);
    margin: var(--space-10) 0;
  }

  .showcase h3 {
    margin-top: 0;
    font-family: var(--font-serif);
    font-size: 1.25rem;
  }

  .showcase-demo {
    margin-bottom: var(--space-6);
  }

  .showcase-demo:empty {
    margin-bottom: 0;
  }

  .showcase-annotations :global(p) {
    margin: 0;
    line-height: var(--leading-body);
  }

  .showcase-annotations {
    font-size: 0.875rem;
    color: var(--color-steel);
    border-top: var(--border-hairline);
    padding-top: var(--space-4);
  }

  .showcase-annotations :global(table) {
    width: 100%;
    border-collapse: collapse;
  }

  .showcase-annotations :global(td) {
    padding: var(--space-2) var(--space-4) var(--space-2) 0;
  }

  .showcase-annotations :global(code) {
    font-size: 0.8125rem;
  }
</style>
