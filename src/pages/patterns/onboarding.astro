---
import DocsLayout from '../../layouts/DocsLayout.astro';
import PhilosophyCallout from '../../components/docs/PhilosophyCallout.astro';
---

<DocsLayout title="Onboarding" description="Cleo onboarding flow pattern">
  <div class="prose">
    <h1>Onboarding flow</h1>
    <p class="page-lead">Frame 5 skepticism: prove it works before asking for commitment.</p>

    <h2>Principles</h2>
    <ul>
      <li>Short steps with plain labels — no gamification</li>
      <li>Show a real note transcription early, not abstract benefits</li>
      <li>Introduce denial prevention before billing integrations</li>
      <li>Allow skip where possible — respect that they may be exhausted</li>
    </ul>

    <PhilosophyCallout>
      <p>Onboarding copy follows voice rules: specific numbers, declarative sentences, acknowledgment before solution.</p>
    </PhilosophyCallout>
  </div>
</DocsLayout>
