---
import DocsLayout from '../../layouts/DocsLayout.astro';
import TypeSpecimen from '../../components/docs/TypeSpecimen.astro';
import ProseSection from '../../components/docs/ProseSection.astro';
import DoDont from '../../components/docs/DoDont.astro';
---

<DocsLayout title="Typography" description="Cleo typography system">
  <div class="prose">
    <h1>Typography</h1>
    <p class="page-lead">
      Humanist serif for authority and warmth. DM Sans for everything the therapist reads and taps.
      Only two weights: 400 and 500.
    </p>
  </div>

  <div class="type-scale-list wide-band">
    <TypeSpecimen
      label="Hero / section title"
      sample="Notes done before you leave the clinic"
      size="clamp(2.25rem, 4vw, 3.5rem)"
      weight="400"
      lineHeight="1.15"
      letterSpacing="-0.01em"
      role="Page titles, emotional headlines"
      example="Landing hero naming the wound before the product"
      variant="serif"
    />
    <TypeSpecimen
      label="Subsection"
      sample="Denial prevention that reads your note"
      size="clamp(1.375rem, 2.5vw, 1.75rem)"
      weight="400"
      lineHeight="1.3"
      role="Section headers in docs and product"
      example="Feature section on the marketing page"
      variant="serif"
    />
    <TypeSpecimen
      label="Body"
      sample="This phrasing may signal maintenance care to insurers. Suggested revision below."
      size="1.0625rem"
      weight="400"
      lineHeight="1.6"
      role="Body copy, form text, denial explanations"
      example="Denial guardian plain-English message"
      variant="sans"
    />
    <TypeSpecimen
      label="Label"
      sample="Initial evaluation"
      size="0.6875rem"
      weight="500"
      lineHeight="1.4"
      letterSpacing="0.08em"
      role="Note type, metadata, UI labels"
      example="Note card type label in small caps"
      variant="sans"
    />
  </div>

  <ProseSection title="Why a humanist serif?" accent>
    <p>Ideal typeface: Freight Display. Implementation: Lora (closest available with Google Fonts).</p>
    <ul>
      <li><strong>Strong bracketed serifs</strong> → groundedness. The headline feels planted, not floating.</li>
      <li><strong>Moderate stroke contrast</strong> → warmth. Not cold Didot elegance; not blunt slab.</li>
      <li><strong>Wide, heavy letterforms</strong> → unhurried authority. Scale does the work — no bold weight needed.</li>
    </ul>
  </ProseSection>

  <ProseSection title="Prohibited patterns">
    <DoDont>
      <p slot="do" style="margin:0">Notes done in under five minutes.</p>
      <p slot="dont" style="margin:0;text-transform:uppercase;letter-spacing:0.2em;font-weight:700">NOTES DONE FAST</p>
    </DoDont>
    <ul>
      <li><strong>All-caps headlines</strong> — too aggressive for an exhausted user</li>
      <li><strong>Tight tracking</strong> — too fashionable, fights readability</li>
      <li><strong>Bold weight (700+)</strong> — performs confidence rather than having it</li>
    </ul>
  </ProseSection>
</DocsLayout>
